# ─────────────────────────────────────────────────────────────────────────────
# PayReconcile — Production Docker Compose (Ansible-templated)
# This file is generated by Ansible on the EC2 instance.
# Do NOT edit manually on the server — it will be overwritten on next deploy.
# ─────────────────────────────────────────────────────────────────────────────

services:

  backend:
    image: {{ backend_image }}
    container_name: payreconcile-backend
    ports:
      - "5000:5000"
    environment:
      - SPRING_DATA_MONGODB_URI={{ mongodb_uri }}
      - STRIPE_SECRET_KEY={{ stripe_secret }}
      - STRIPE_PUBLISHABLE_KEY={{ stripe_publishable }}
      - STRIPE_WEBHOOK_SECRET={{ stripe_webhook_secret }}
      - MAIL_USERNAME={{ mail_username }}
      - MAIL_PASSWORD={{ mail_password }}
      - AWS_ACCESS_KEY_ID={{ aws_access_key }}
      - AWS_SECRET_ACCESS_KEY={{ aws_secret_key }}
      - AWS_REGION=us-east-1
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - CACHE_TYPE=redis
      - KAFKA_BROKERS=kafka:29092
    depends_on:
      - redis
      - kafka
    restart: unless-stopped
    networks:
      - payreconcile-net

  frontend:
    image: {{ frontend_image }}
    container_name: payreconcile-frontend
    ports:
      - "3000:80"
    restart: unless-stopped
    networks:
      - payreconcile-net

  redis:
    image: redis:7-alpine
    container_name: payreconcile-redis
    restart: unless-stopped
    networks:
      - payreconcile-net

  kafka:
    image: confluentinc/cp-kafka:7.4.4
    container_name: payreconcile-kafka
    environment:
      KAFKA_NODE_ID: 1
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://kafka:29092,PLAINTEXT_HOST://localhost:9092
      KAFKA_PROCESS_ROLES: broker,controller
      KAFKA_CONTROLLER_QUORUM_VOTERS: 1@kafka:29093
      KAFKA_LISTENERS: PLAINTEXT://kafka:29092,CONTROLLER://kafka:29093,PLAINTEXT_HOST://0.0.0.0:9092
      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT
      KAFKA_CONTROLLER_LISTENER_NAMES: CONTROLLER
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
      CLUSTER_ID: payreconcile-cluster-1
    restart: unless-stopped
    networks:
      - payreconcile-net

networks:
  payreconcile-net:
    driver: bridge
